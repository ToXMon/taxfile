# Database mode (set automatically by Akash SDL - shown for local dev)
# 'json' = flat-file storage in /data/ (default, no DB required)
# 'prisma' = PostgreSQL via Prisma (production)
DATABASE=json

# PostgreSQL (only needed when DATABASE=prisma)
DATABASE_URL=postgresql://taxfile:changeme-secure-password@localhost:5432/taxfile
DIRECT_URL=postgresql://taxfile:changeme-secure-password@localhost:5432/taxfile
